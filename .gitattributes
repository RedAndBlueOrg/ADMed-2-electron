*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.ico    binary
*.icns   binary
*.zip    binary
*.7z     binary
*.gz     binary
*.tar    binary
*.exe    binary
*.dll    binary
*.dmg    binary
*.mp4    binary
*.mp3    binary
*.wav    binary
*.otf    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.pdf    binary
